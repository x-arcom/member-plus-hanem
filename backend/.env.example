# Backend environment configuration for Member Plus

# ------- Required --------------------------------------------------------
SALLA_API_KEY=your-salla-api-key
SALLA_WEBHOOK_SECRET=your-salla-webhook-secret
DATABASE_URL=sqlite:///memberplus_phase1.db
ENVIRONMENT=development

# Generate both values with:  python -m config.gen_keys
JWT_SECRET=change-me-at-least-32-chars-long
ENCRYPTION_KEY=generate-a-fernet-key-with-gen_keys

# ------- CORS / security -------------------------------------------------
# Comma-separated allowlist of origins permitted to call the backend.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ------- Salla OAuth (Phase 1 Full) -------------------------------------
SALLA_CLIENT_ID=your-salla-oauth-client-id
SALLA_CLIENT_SECRET=your-salla-oauth-client-secret
SALLA_OAUTH_AUTHORIZE_URL=https://accounts.salla.sa/oauth2/auth
SALLA_OAUTH_TOKEN_URL=https://accounts.salla.sa/oauth2/token
SALLA_OAUTH_REDIRECT_URI=http://localhost:8000/api/oauth/callback
SALLA_STORE_INFO_URL=https://api.salla.dev/admin/v2/store/info

# ------- Email / SMTP (Phase 1 Full) ------------------------------------
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=smtp-user
EMAIL_PASSWORD=smtp-password
EMAIL_FROM="Member Plus <no-reply@memberplus.com>"
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

# ------- Payments (Phase 3) ---------------------------------------------
# `mock` (default) uses in-memory MockPaymentAdapter — Phase 2 behaviour.
# `moyasar` switches on the Moyasar HTTP adapter when MOYASAR_API_KEY is set.
PAYMENT_PROVIDER=mock
MOYASAR_API_KEY=
MOYASAR_BASE_URL=https://api.moyasar.com
MOYASAR_CALLBACK_URL=http://localhost:3000/plans.html#billing

# ------- Scheduler (Phase 4) --------------------------------------------
# Set to false in test / CI runs. Default is true — APScheduler will run
# refresh_expiring_tokens every 5 min and trial_reminders daily at 09:00.
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
TRIAL_REMINDER_DAYS=3

# ------- Observability ---------------------------------------------------
LOG_LEVEL=INFO
