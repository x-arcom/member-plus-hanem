{
  "version": 2,
  "builds": [
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/frontend/index.html" },
    { "src": "^/api/(.*)", "dest": "https://heritage-gem-armoire.ngrok-free.dev/api/$1" },
    { "src": "^/webhooks/(.*)", "dest": "https://heritage-gem-armoire.ngrok-free.dev/webhooks/$1" },
    { "src": "^/health$", "dest": "https://heritage-gem-armoire.ngrok-free.dev/health" },
    { "src": "^/legal/(.*)", "dest": "https://heritage-gem-armoire.ngrok-free.dev/legal/$1" },
    { "src": "^/frontend/(.*)", "dest": "/frontend/$1" }
  ]
}
